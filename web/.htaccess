# ----------------------------------------------------------------------
# DISABLE CACHING FOR FLUTTER APP ENTRY POINTS
# ----------------------------------------------------------------------
<FilesMatch "^(index\.html|flutter_service_worker\.js|flutter_bootstrap\.js|flutter\.js|main\.dart\.js|version\.json|manifest\.json)$">
    FileETag None
    <IfModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </IfModule>
</FilesMatch>

# ----------------------------------------------------------------------
# SINGLE PAGE APPLICATION ROUTING FOR FLUTTER
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Stop processing if the request is already explicitly for index.html
  RewriteRule ^index\.html$ - [L]
  
  # If the requested file or directory does not exist on the server...
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # ...route the request directly to index.html so Flutter's router can handle it
  RewriteRule . /index.html [L]
</IfModule>

